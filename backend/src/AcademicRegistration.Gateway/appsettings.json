{
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "academic-registration-api": {
        "ClusterId": "academic-registration-api",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "academic-registration-api": {
        "Destinations": {
          "api": {
            "Address": "http://localhost:5081/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
