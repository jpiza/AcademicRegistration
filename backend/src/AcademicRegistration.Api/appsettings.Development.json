{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "EventBridge": {
    "EventBusName": "academic-registration",
    "Source": "academic-registration.api",
    "Region": "us-east-1",
    "ServiceUrl": "http://localhost:4566"
  },
  "Outbox": {
    "BatchSize": 20,
    "PollingIntervalSeconds": 5,
    "MaxRetries": 0
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "Tracing": {
    "XRay": {
      "Enabled": false
    }
  }
}
